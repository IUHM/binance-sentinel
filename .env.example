APP_PORT=80

POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change_me_please
DATABASE_URL=postgresql+psycopg://sentinel:change_me_please@postgres:5432/sentinel

# 海外 VPS 建议保持同域部署，前端会自动走当前域名。
# 如果你要把前端放到别的域名，再手动填完整地址，例如 https://api.example.com
VITE_API_BASE_URL=
CORS_ORIGINS=*

BINANCE_REST_BASE_URL=https://fapi.binance.com
BINANCE_WS_BASE_URL=wss://fstream.binance.com
SYMBOL_REFRESH_SECONDS=1800
INTEL_POLL_SECONDS=60
FUNDING_HISTORY_SAMPLE_SECONDS=120
FUNDING_HISTORY_RETENTION_HOURS=72
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 官方和媒体源使用逗号分隔
OFFICIAL_RSS_URLS=
MEDIA_RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://decrypt.co/feed,https://cointelegraph.com/rss

# X 白名单通过 RSS 代理接入，例如：
# X_SOURCE_TEMPLATE=https://nitter.poast.org/{handle}/rss
X_SOURCE_TEMPLATE=
X_WHITELIST=binance,lookonchain,WuBlockchain
